# API Keys (server-side only, never in browser)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Server
PORT=3001
HOST=localhost

# Optional password (leave empty to disable)
APP_PASSWORD=

# Database path
DB_PATH=./data/evoq-assistant.db

# Max file upload size in bytes (default 10MB)
MAX_FILE_SIZE=10485760

# Session timeout in minutes (0 = disabled)
SESSION_TIMEOUT_MINUTES=60

# Auto-delete conversations older than N days (0 = disabled)
CONVERSATION_TTL_DAYS=0

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

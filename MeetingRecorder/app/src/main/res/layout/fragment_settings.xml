<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- AssemblyAI API Key (transcription + diarisation) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_assembly_key"
            app:endIconMode="password_toggle"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAssemblyKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Anthropic API Key (résumé Claude) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_anthropic_key"
            app:endIconMode="password_toggle"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAnthropicKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Meeting title template -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_meeting_title"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMeetingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Chunk duration slider -->
        <TextView
            android:id="@+id/tvChunkLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/on_background"
            android:layout_marginBottom="4dp"
            android:text="@string/label_chunk_duration" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderChunkDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="5"
            android:valueTo="20"
            android:stepSize="5"
            android:value="15"
            android:layout_marginBottom="24dp" />

        <!-- Expected speaker count slider -->
        <TextView
            android:id="@+id/tvSpeakerLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/on_background"
            android:layout_marginBottom="4dp"
            android:text="@string/label_speaker_count" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderSpeakers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="2"
            android:valueTo="10"
            android:stepSize="1"
            android:value="4"
            android:layout_marginBottom="32dp" />

        <!-- Save -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_save" />

        <!-- EVOQ logo + copyright -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:src="@drawable/evoq_logo"
            android:adjustViewBounds="true"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:contentDescription="EVOQ Architecture" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="© Eric Stein, EVOQ Architecture"
            android:textSize="11sp"
            android:textColor="@color/secondary_text" />

    </LinearLayout>

</ScrollView>

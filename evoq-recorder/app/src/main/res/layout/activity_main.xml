<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/evoq_black">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/evoq_black"
        android:elevation="0dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingBottom="40dp">

        <!-- Logo — white bg on white app bg: add card shadow so it reads as a panel -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="10dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="36dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/evoq_logo"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:paddingHorizontal="28dp"
                android:paddingVertical="22dp"
                android:contentDescription="EVOQ Architecture" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/field_recorder_subtitle"
            android:textColor="@color/evoq_white"
            android:textSize="18sp"
            android:letterSpacing="0.06"
            android:layout_marginBottom="10dp" />

        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:background="@color/evoq_gold"
            android:layout_marginBottom="36dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_language"
            android:textColor="@color/evoq_grey"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnEnglish"
            android:layout_width="240dp"
            android:layout_height="58dp"
            android:text="English"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:background="@color/evoq_gold"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnFrench"
            android:layout_width="240dp"
            android:layout_height="58dp"
            android:text="Français"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:background="@color/evoq_gold" />

    </LinearLayout>

</LinearLayout>

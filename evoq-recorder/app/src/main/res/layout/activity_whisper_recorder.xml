<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/evoq_black">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/evoq_black"
        android:elevation="0dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/evoq_logo"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="EVOQ" />

    </androidx.appcompat.widget.Toolbar>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/evoq_gold" />

    <!-- Status area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/ivMicIndicator"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_mic_large"
            android:alpha="0.25" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/ready_to_record"
            android:textColor="@color/evoq_gold"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/evoq_white"
            android:textSize="42sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Whisper transcribing indicator -->
    <LinearLayout
        android:id="@+id/layoutTranscribing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/transcribing_whisper"
            android:textColor="@color/evoq_grey"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Transcript label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:text="@string/live_transcript"
        android:textColor="@color/evoq_gold"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.12" />

    <!-- Transcript scroll area -->
    <ScrollView
        android:id="@+id/scrollTranscript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/evoq_dark_grey"
        android:padding="14dp"
        android:layout_marginHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTranscriptHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/whisper_transcript_hint"
                android:textColor="@color/evoq_grey"
                android:textSize="15sp"
                android:gravity="center"
                android:paddingVertical="16dp" />

            <TextView
                android:id="@+id/tvTranscript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/evoq_white"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

    </ScrollView>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:layout_margin="16dp">

        <Button
            style="@style/Widget.AppCompat.Button"
            android:id="@+id/btnPauseResume"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/start_recording"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@color/evoq_gold" />

        <Button
            style="@style/Widget.AppCompat.Button"
            android:id="@+id/btnGenerateReport"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/generate_report"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@color/recording_red"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>

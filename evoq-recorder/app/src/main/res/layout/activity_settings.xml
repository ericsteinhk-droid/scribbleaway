<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/evoq_black">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/evoq_black"
        android:elevation="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/claude_api_key_label"
            android:textColor="@color/evoq_gold"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:textColor="@color/evoq_white"
            android:textColorHint="@color/evoq_grey"
            android:background="@color/evoq_dark_grey"
            android:padding="12dp"
            android:inputType="textPassword"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/api_key_hint"
            android:textColor="@color/evoq_grey"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/save"
            android:textColor="@color/evoq_black"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:background="@color/evoq_gold" />

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/evoq_black">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/evoq_black"
        android:elevation="2dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/evoq_logo"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="EVOQ" />

    </androidx.appcompat.widget.Toolbar>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/evoq_gold" />

    <!-- Sort + Regenerate row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/evoq_dark_grey"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/spinnerSort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/evoq_gold"
            android:popupBackground="@color/evoq_black" />

        <Button
            style="@style/Widget.AppCompat.Button"
            android:id="@+id/btnRegenerate"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/regenerate"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@color/evoq_gold"
            android:layout_marginStart="10dp"
            android:paddingHorizontal="16dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/evoq_gold"
        android:visibility="gone"
        android:layout_marginTop="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/evoq_white"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.6"
                android:fontFamily="sans-serif" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/evoq_dark_grey"
                android:layout_marginVertical="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/raw_transcript_label"
                android:textColor="@color/evoq_gold"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTranscriptPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/evoq_grey"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

    </ScrollView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="16dp">

        <Button
            style="@style/Widget.AppCompat.Button"
            android:id="@+id/btnDownloadDocx"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:text="@string/download_docx"
            android:textColor="@color/evoq_gold"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@color/evoq_dark_grey"
            android:layout_marginEnd="10dp"
            android:enabled="false" />

        <Button
            style="@style/Widget.AppCompat.Button"
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:text="@string/share_report"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@color/evoq_gold"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>
